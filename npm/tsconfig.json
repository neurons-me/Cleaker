{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["jest", "node"]
  }
  ,
  "include": [
    "src/**/*",
    "server.ts"
  ]
  ,
  "exclude": [
    "tests/**/*"
  ]
}
